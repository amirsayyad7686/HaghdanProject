<%- include('partials/header') %>

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Transparent Ledger</h1>
        <p class="text-slate-600 mt-2">A live, auditable list of capital, physical equipment, facilities, and expertise.</p>
    </div>
    <% if (userRole === 'investor_provider') { %>
        <a href="/dashboard" class="bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold py-2.5 px-5 rounded-lg shadow-sm transition-all">+ Inject New Asset</a>
    <% } %>
</div>

<div class="bg-white shadow-sm rounded-2xl border border-slate-200 overflow-hidden">
    <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
            <thead class="bg-slate-50 text-slate-500 uppercase tracking-wider text-[10px] font-bold">
                <tr>
                    <th class="px-6 py-4">Asset ID</th>
                    <th class="px-6 py-4">Provider / Donor</th>
                    <th class="px-6 py-4">Resource Category</th>
                    <th class="px-6 py-4">Details / Volume</th>
                    <th class="px-6 py-4 text-right">Allocation Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
                <% if (data.length === 0) { %>
                    <tr><td colspan="5" class="px-6 py-8 text-center text-slate-500 italic">No assets currently registered in the ledger.</td></tr>
                <% } else { %>
                    <% data.forEach(item => { %>
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 font-mono text-xs text-slate-400"><%= item._id.toString().slice(-6) %></td>
                            <td class="px-6 py-4 font-bold text-slate-900"><%= item.provider.name %></td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100 uppercase tracking-wider">
                                    <%= item.type %>
                                </span>
                            </td>
                            <td class="px-6 py-4 text-slate-600 font-medium"><%= item.detail %></td>
                            <td class="px-6 py-4 text-right">
                                <span class="text-xs font-semibold <%= item.status === 'Unallocated' ? 'text-emerald-600' : 'text-slate-400' %>"><%= item.status %></span>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <div class="block md:hidden divide-y divide-slate-100">
        <% if (data.length === 0) { %>
            <div class="p-6 text-center text-slate-500 italic">No assets registered.</div>
        <% } else { %>
            <% data.forEach(item => { %>
                <div class="p-5 bg-white space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="font-bold text-slate-900"><%= item.provider.name %></span>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100 uppercase">
                            <%= item.type %>
                        </span>
                    </div>
                    <div class="text-sm text-slate-600 bg-slate-50 p-3 rounded-lg border border-slate-100"><%= item.detail %></div>
                    <div class="flex justify-between items-center text-xs">
                        <span class="font-mono text-slate-400">ID: <%= item._id.toString().slice(-6) %></span>
                        <span class="font-semibold <%= item.status === 'Unallocated' ? 'text-emerald-600' : 'text-slate-400' %>"><%= item.status %></span>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
    
    <div class="bg-white px-4 py-4 flex flex-col sm:flex-row items-center justify-between border-t border-slate-200">
        <p class="text-xs font-semibold text-slate-500 mb-4 sm:mb-0">
            Page <%= currentPage %> of <%= totalPages %>
        </p>
        <nav class="relative z-0 inline-flex rounded-md shadow-sm" aria-label="Pagination">
            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %>" class="relative inline-flex items-center px-4 py-2 border text-sm font-medium <%= currentPage === i ? 'z-10 bg-emerald-600 border-emerald-600 text-white' : 'bg-white border-slate-300 text-slate-500 hover:bg-slate-50' %>">
                    <%= i %>
                </a>
            <% } %>
        </nav>
    </div>
</div>

<%- include('partials/footer') %>