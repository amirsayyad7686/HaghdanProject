<%- include('partials/header') %>

<div class="max-w-md mx-auto bg-white p-8 border border-slate-200 rounded-2xl shadow-sm mt-12 mb-20">
    <div class="text-center mb-8">
        <h2 class="text-2xl font-extrabold text-slate-900">Join the Syndicate</h2>
        <p class="text-sm text-slate-500 mt-2">Register as an asset provider or a technical builder.</p>
    </div>

    <form action="/register" method="POST" class="space-y-5">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Full Name / Organization</label>
            <input type="text" name="name" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all">
        </div>
        
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Email Address</label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all">
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Phone Number') %></label>
            <input type="tel" name="phone" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none transition-all" placeholder="0912...">
        </div>
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all">
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Operating Role</label>
            <select name="role" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none bg-white">
                <option value="" disabled selected>Select your function...</option>
                <option value="investor_provider">Asset Provider (Capital / Facilities)</option>
                <option value="entrepreneur_builder">Entrepreneur (Projects / Execution)</option>
            </select>
        </div>

        <button type="submit" class="w-full bg-slate-900 hover:bg-emerald-600 text-white font-bold py-3 rounded-lg transition-colors mt-4">
            Initialize Account
        </button>
    </form>
    
    <p class="text-center text-sm text-slate-600 mt-6">
        Already registered? <a href="/login" class="text-emerald-600 font-semibold hover:underline">Access Workspace</a>
    </p>
</div>

<%- include('partials/footer') %>