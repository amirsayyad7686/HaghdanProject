<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master Admin Console</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 font-sans text-slate-900 pb-20">
    
    <div class="bg-slate-900 text-white p-6 shadow-md mb-8">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-black tracking-tight">System Admin Console</h1>
            <a href="/" class="text-sm font-bold text-slate-300 hover:text-white transition-colors">Back to Main Site &rarr;</a>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="bg-slate-800 p-4 border-b border-slate-700">
                    <h2 class="text-lg font-bold text-white">Registered Users (<%= users.length %>)</h2>
                </div>
                <div class="max-h-[800px] overflow-y-auto divide-y divide-slate-100">
                    <% users.forEach(u => { %>
                        <div class="p-4 hover:bg-slate-50 transition-colors">
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="font-bold text-sm text-slate-900"><%= u.name %></h3>
                                <span class="text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider <%= u.role === 'investor_provider' ? 'bg-emerald-100 text-emerald-700' : 'bg-blue-100 text-blue-700' %>">
                                    <%= u.role === 'investor_provider' ? 'Provider' : 'Builder' %>
                                </span>
                            </div>
                            <p class="text-xs text-slate-500 font-mono"><%= u.email %></p>
                            <p class="text-xs text-slate-500 font-mono mt-1"><%= u.phone %></p>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div class="bg-indigo-600 p-4 rounded-2xl shadow-sm text-white flex justify-between items-center">
                <h2 class="text-lg font-bold">Project Execution Stories</h2>
                <span class="text-sm font-medium bg-indigo-800 px-3 py-1 rounded-lg"><%= projects.length %> Total Projects</span>
            </div>

            <% if (projects.length === 0) { %>
                <div class="bg-amber-50 border border-amber-200 p-6 rounded-xl text-center">
                    <p class="text-amber-800 font-medium">No projects exist in the system yet.</p>
                </div>
            <% } else { %>
                <% projects.forEach(p => { %>
                    <details class="bg-white rounded-2xl shadow-sm border border-slate-200 group overflow-hidden">
                        <summary class="p-6 cursor-pointer list-none flex justify-between items-center hover:bg-slate-50 transition-colors">
                            <div>
                                <div class="flex gap-2 mb-2">
                                    <span class="text-[10px] font-bold px-2 py-1 rounded <%= p.status === 'Fully Backed' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                                        <%= p.status %>
                                    </span>
                                    <span class="text-[10px] font-bold px-2 py-1 rounded bg-slate-100 text-slate-500 font-mono">ID: <%= p._id.toString().slice(-4) %></span>
                                </div>
                                <h3 class="text-xl font-bold text-slate-900"><%= p.title %></h3>
                                <p class="text-xs text-slate-500 mt-1">Founder: <%= p.founder.name %> <%= p.backer ? '| Backer: ' + p.backer.name : '' %></p>
                            </div>
                            <div class="flex items-center gap-4">
                                <form action="/api/admin/projects/<%= p._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to completely delete this project?');">
                                    <button type="submit" class="text-xs font-bold text-red-500 hover:bg-red-50 px-3 py-2 rounded-lg transition-colors border border-red-200">Delete Project</button>
                                </form>
                                <span class="text-slate-400 group-open:rotate-180 transition-transform">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </span>
                            </div>
                        </summary>

                        <div class="p-6 border-t border-slate-100 bg-slate-50">
                            
                            <h4 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-4 border-b border-slate-200 pb-2">Existing Steps (<%= p.milestones.length %>)</h4>
                            <% if (p.milestones.length > 0) { %>
                                <div class="space-y-4 mb-8">
                                    <% p.milestones.forEach(step => { %>
                                        <div class="bg-white p-4 border border-slate-200 rounded-xl shadow-sm">
                                            <form action="/api/admin/projects/<%= p._id %>/step/<%= step._id %>/edit" method="POST" enctype="multipart/form-data" class="flex flex-col md:flex-row gap-4">
                                                <div class="w-16">
                                                    <label class="text-[10px] font-bold text-slate-400 uppercase">Step #</label>
                                                    <input type="number" name="stepNumber" value="<%= step.stepNumber %>" required class="w-full border border-slate-300 rounded p-2 text-sm text-center">
                                                </div>
                                                <div class="flex-1">
                                                    <label class="text-[10px] font-bold text-slate-400 uppercase">Description</label>
                                                    <textarea name="description" rows="2" required class="w-full border border-slate-300 rounded p-2 text-sm"><%= step.description %></textarea>
                                                </div>
                                                <div class="w-48">
                                                    <label class="text-[10px] font-bold text-slate-400 uppercase">Replace Image</label>
                                                    <input type="file" name="image" accept="image/*" class="w-full text-xs text-slate-500 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 mt-1">
                                                    <% if (step.image) { %>
                                                        <a href="<%= step.image %>" target="_blank" class="text-[10px] text-blue-500 hover:underline mt-1 block">View Current Image</a>
                                                    <% } %>
                                                </div>
                                                <div class="flex flex-col gap-2 justify-end">
                                                    <button type="submit" class="bg-indigo-600 text-white text-xs font-bold px-3 py-2 rounded shadow-sm hover:bg-indigo-700">Save Edit</button>
                                            </form>
                                            <form action="/api/admin/projects/<%= p._id %>/step/<%= step._id %>/delete" method="POST" class="w-full" onsubmit="return confirm('Delete this step?');">
                                                    <button type="submit" class="w-full bg-slate-200 text-red-600 text-xs font-bold px-3 py-2 rounded hover:bg-red-100">Delete</button>
                                            </form>
                                                </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p class="text-sm text-slate-500 italic mb-8">No steps added yet.</p>
                            <% } %>

                            <h4 class="text-sm font-bold text-emerald-700 uppercase tracking-wider mb-4 border-b border-emerald-200 pb-2">+ Add New Step</h4>
                            <form action="/api/admin/step" method="POST" enctype="multipart/form-data" class="bg-white p-5 rounded-xl border border-emerald-200 shadow-sm space-y-4">
                                <input type="hidden" name="projectId" value="<%= p._id %>">
                                
                                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                                    <div class="md:col-span-1">
                                        <label class="block text-xs font-bold text-slate-700 mb-1">Step Number</label>
                                        <input type="number" name="stepNumber" required min="1" value="<%= p.milestones.length + 1 %>" class="w-full p-2 border border-slate-300 rounded-lg outline-none focus:border-emerald-500">
                                    </div>
                                    <div class="md:col-span-3">
                                        <label class="block text-xs font-bold text-slate-700 mb-1">Upload Image (Optional)</label>
                                        <input type="file" name="image" accept="image/*" class="w-full p-1.5 border border-slate-300 rounded-lg text-sm file:mr-4 file:py-1 file:px-4 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100">
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-xs font-bold text-slate-700 mb-1">Step Description</label>
                                    <textarea name="description" rows="2" required class="w-full p-3 border border-slate-300 rounded-lg outline-none focus:border-emerald-500" placeholder="Detail what was accomplished..."></textarea>
                                </div>

                                <button type="submit" class="bg-emerald-600 text-white font-bold py-2 px-6 rounded-lg hover:bg-emerald-700 transition-colors w-full md:w-auto shadow-sm">
                                    Push to Public Timeline
                                </button>
                            </form>

                        </div>
                    </details>
                <% }) %>
            <% } %>
        </div>
    </div>
</body>
</html>