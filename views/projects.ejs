<%- include('partials/header') %>

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Project Pipeline</h1>
        <p class="text-slate-600 mt-2">Review emerging startups alongside their specific bottlenecks and facility resource gaps.</p>
    </div>
    <% if (userRole === 'entrepreneur_builder') { %>
        <a href="/dashboard" class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold py-2.5 px-5 rounded-lg shadow-sm transition-all">+ Draft New Project</a>
    <% } %>
</div>

<% if (projects.length === 0) { %>
    <div class="p-12 bg-white border border-slate-200 rounded-3xl text-center shadow-sm">
        <h3 class="text-lg font-bold text-slate-900">No Projects Live</h3>
        <p class="text-sm text-slate-500 mt-1">The pipeline is currently awaiting new entrepreneurial submissions.</p>
    </div>
<% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% projects.forEach(project => { %>
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 flex flex-col justify-between hover:shadow-md hover:border-blue-300 transition-all">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <span class="text-[10px] font-bold text-blue-700 bg-blue-50 border border-blue-100 px-2.5 py-1 rounded-md uppercase tracking-wider">
                            ID: <%= project._id.toString().slice(-6) %>
                        </span>
                        <span class="text-xs font-semibold text-slate-500">By <%= project.founder.name %></span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 mb-2"><%= project.title %></h3>
                    <p class="text-sm text-slate-600 line-clamp-3 mb-4"><%= project.description %></p>
                </div>
                
                <div class="mt-2 pt-4 border-t border-slate-100">
                    <h4 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Resource Constraints & Needs:</h4>
                    <p class="text-sm text-slate-700 bg-slate-50 p-3 rounded-xl border border-slate-200 font-medium italic">
                        "<%= project.needs %>"
                    </p>
                    
                    <a href="/cooperate?filter=projects" class="w-full mt-5 bg-slate-900 hover:bg-blue-600 text-white text-xs font-bold py-3 px-4 rounded-xl transition-colors text-center inline-block shadow-sm">
                        View in Matrix to Back
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<%- include('partials/footer') %>