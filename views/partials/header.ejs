<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col">
    
    <nav class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50 transition-all">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                
                <div class="flex items-center gap-8">
                    <a href="/" class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-500 tracking-tight hover:opacity-80 transition-opacity">
                        Matrix Hub.
                    </a>
                    <div class="hidden md:flex space-x-1">
                        <a href="/" class="text-slate-600 hover:text-emerald-600 hover:bg-slate-50 px-4 py-2 rounded-lg font-medium text-sm transition-all">Home</a>
                        <a href="/contributions" class="text-slate-600 hover:text-emerald-600 hover:bg-slate-50 px-4 py-2 rounded-lg font-medium text-sm transition-all">Live Assets</a>
                        <a href="/projects" class="text-slate-600 hover:text-emerald-600 hover:bg-slate-50 px-4 py-2 rounded-lg font-medium text-sm transition-all">Project Pipeline</a>
                        <a href="/cooperate" class="text-slate-600 hover:text-emerald-600 hover:bg-slate-50 px-4 py-2 rounded-lg font-medium text-sm transition-all">Matrix</a>
                    </div>
                </div>

                <div class="hidden md:flex items-center space-x-3">
                    <% if (sessionUserId) { %>
                        <a href="/dashboard" class="bg-slate-900 hover:bg-slate-800 text-white px-5 py-2.5 rounded-lg font-semibold text-sm shadow-sm transition-all">Workspace</a>
                        <a href="/logout" class="text-slate-500 hover:text-red-600 px-3 py-2 font-medium text-sm transition-colors">Terminate</a>
                    <% } else { %>
                        <a href="/login" class="text-slate-600 hover:text-emerald-600 px-4 py-2 font-medium text-sm transition-colors">Log In</a>
                        <a href="/register" class="bg-emerald-600 hover:bg-emerald-500 text-white px-5 py-2.5 rounded-lg font-semibold text-sm shadow-sm hover:shadow transition-all">Register</a>
                    <% } %>
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="text-slate-600 hover:text-emerald-600 focus:outline-none p-2 cursor-pointer">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-200 absolute w-full shadow-lg z-40">
            <div class="px-4 pt-2 pb-6 flex flex-col space-y-2">
                <a href="/" class="block px-3 py-3 text-slate-700 hover:bg-slate-50 hover:text-emerald-600 rounded-md font-bold text-base">Home</a>
                <a href="/contributions" class="block px-3 py-3 text-slate-700 hover:bg-slate-50 hover:text-emerald-600 rounded-md font-bold text-base">Live Assets</a>
                <a href="/projects" class="block px-3 py-3 text-slate-700 hover:bg-slate-50 hover:text-emerald-600 rounded-md font-bold text-base">Project Pipeline</a>
                <a href="/cooperate" class="block px-3 py-3 text-slate-700 hover:bg-slate-50 hover:text-emerald-600 rounded-md font-bold text-base">The Matrix</a>
                
                <hr class="my-3 border-slate-100">
                
                <% if (sessionUserId) { %>
                    <a href="/dashboard" class="block w-full px-3 py-3 bg-slate-900 text-white rounded-lg font-bold text-center">Workspace Command</a>
                    <a href="/logout" class="block w-full px-3 py-3 text-red-600 hover:bg-red-50 rounded-lg font-bold text-center mt-2">Terminate Session</a>
                <% } else { %>
                    <a href="/login" class="block w-full px-3 py-3 text-slate-700 border border-slate-300 rounded-lg font-bold text-center">Log In</a>
                    <a href="/register" class="block w-full px-3 py-3 bg-emerald-600 text-white rounded-lg font-bold text-center mt-2">Register</a>
                <% } %>
            </div>
        </div>
    </nav>
    
    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">

    <script>
        document.getElementById('mobile-menu-button').addEventListener('click', () => {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });
    </script>