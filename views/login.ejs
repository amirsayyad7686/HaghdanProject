<%- include('partials/header') %>

<div class="max-w-md mx-auto bg-white p-8 border border-slate-200 rounded-2xl shadow-sm mt-12 mb-20">
    <div class="text-center mb-8">
        <h2 class="text-2xl font-extrabold text-slate-900">Workspace Access</h2>
        <p class="text-sm text-slate-500 mt-2">Enter your credentials to manage your assets or projects.</p>
    </div>

    <form action="/login" method="POST" class="space-y-5">
        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Email Address</label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
        </div>

        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3 rounded-lg transition-colors mt-4">
            Authorize Entry
        </button>
    </form>
</div>

<%- include('partials/footer') %>