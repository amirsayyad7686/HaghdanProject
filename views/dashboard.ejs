<%- include('partials/header') %>

<div class="mb-10 bg-white p-8 rounded-3xl border border-slate-200 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
    <div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-3
            <%= user.role === 'investor_provider' ? 'bg-teal-50 text-teal-700 border border-teal-200' : 'bg-blue-50 text-blue-700 border border-blue-200' %>">
            <%= user.role === 'investor_provider' ? __('Asset Provider Terminal') : __('Entrepreneur Terminal') %>
        </span>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight"><%= __('Workspace') %>, <%= user.name %></h1>
        <p class="text-slate-500 mt-2 text-sm max-w-2xl"><%= __('Use this command center to inject resources into the ecosystem or request backing for your validated projects.') %></p>
    </div>
    <a href="/logout" class="text-sm font-semibold text-red-600 hover:text-red-700 hover:underline transition-colors"><%= __('Terminate') %></a>
</div>

<% if (successMsg && successMsg.length > 0) { %>
    <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl shadow-sm flex items-center justify-between animate-fade-in-down">
        <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="font-semibold text-sm"><%= successMsg %></span>
        </div>
    </div>
<% } %>

<% if (errorMsg && errorMsg.length > 0) { %>
    <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl shadow-sm flex items-center gap-2 animate-fade-in-down">
        <span class="w-2 h-2 rounded-full bg-red-500"></span>
        <span class="font-semibold text-sm"><%= errorMsg %></span>
    </div>
<% } %>

<% if (query && query.action === 'new_deal') { %>
    <div class="mb-8 bg-indigo-50 border border-indigo-200 p-6 rounded-3xl shadow-sm">
        <h2 class="text-xl font-bold text-indigo-900 mb-2"><%= __('Initiate Deal Application') %></h2>
        <p class="text-sm text-indigo-700 mb-4"><%= __('You are opening a direct communication channel regarding a Matrix listing. Detail your proposal below.') %></p>
        
        <form action="/api/deals" method="POST" class="bg-white p-5 rounded-2xl border border-indigo-100">
            <input type="hidden" name="targetType" value="<%= query.target_type %>">
            <input type="hidden" name="targetId" value="<%= query.target_id %>">
            <input type="hidden" name="receiverId" value="<%= query.receiver_id %>">
            
            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Your Pitch / Term Sheet Proposal') %></label>
            <textarea name="message" rows="4" required placeholder="<%= __('Outline how your resources match their needs...') %>" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none mb-4"></textarea>
            
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl shadow-sm transition-all cursor-pointer">
                <%= __('Send Syndication Request') %>
            </button>
            <a href="/dashboard" class="ml-4 text-sm font-medium text-slate-500 hover:text-slate-800"><%= __('Cancel') %></a>
        </form>
    </div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="bg-slate-900 px-6 py-4 border-b border-slate-800">
                <h2 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full <%= user.role === 'investor_provider' ? 'bg-emerald-400' : 'bg-blue-400' %> animate-pulse"></span>
                    <%= user.role === 'investor_provider' ? __('Register New Asset to Pool') : __('Draft New Project Proposal') %>
                </h2>
            </div>
            <div class="p-6">
                <% if (user.role === 'investor_provider') { %>
                    <form action="/api/contributions" method="POST" class="space-y-5">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Asset Category') %></label>
                            <select name="type" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none cursor-pointer">
                                <option value="Liquid Capital"><%= __('Liquid Capital (Funding)') %></option>
                                <option value="Heavy Equipment"><%= __('Heavy Equipment / Hardware') %></option>
                                <option value="Real Estate/Facilities"><%= __('Real Estate / Facilities') %></option>
                                <option value="Technical Leverage"><%= __('Technical Skill / Expertise') %></option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Asset Details & Volume') %></label>
                            <textarea name="detail" rows="3" required placeholder="<%= __('e.g., $15,000 USD via Escrow...') %>" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500 outline-none"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3.5 rounded-xl transition-all cursor-pointer"><%= __('Deploy Asset to Ledger') %></button>
                    </form>
                <% } else { %>
                    <form action="/api/projects" method="POST" class="space-y-5">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Project Title') %></label>
                            <input type="text" name="title" required placeholder="<%= __('e.g., Autonomous Agri-Drones') %>" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Executive Summary / Concept') %></label>
                            <textarea name="description" rows="3" required placeholder="<%= __('Detail the market problem and your technical solution...') %>" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1"><%= __('Specific Asset Requirements') %></label>
                            <textarea name="needs" rows="2" required placeholder="<%= __('e.g., Require access to CNC machinery...') %>" class="w-full px-4 py-3 bg-red-50 border border-red-200 rounded-xl focus:ring-2 focus:ring-red-500 outline-none placeholder-red-300"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 rounded-xl transition-all cursor-pointer"><%= __('Submit Project to Matrix') %></button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>

    <div class="space-y-6">
        <div class="bg-slate-50 rounded-3xl border border-slate-200 p-6">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-4"><%= user.role === 'investor_provider' ? __('Your Deployment Status') : __('Pipeline Status') %></h3>
            <div class="text-center py-8">
                <div class="text-4xl font-black <%= user.role === 'investor_provider' ? 'text-emerald-600' : 'text-blue-600' %> mb-2"><%= itemCount %></div>
                <p class="text-xs text-slate-500 font-medium"><%= __('Active Items on Matrix') %></p>
            </div>
        </div>

        <div class="bg-slate-50 border border-slate-200 rounded-xl p-6 shadow-sm max-h-96 overflow-y-auto">
            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wider mb-4"><%= __('Syndication Inbox') %></h3>
            <% if (deals && deals.length > 0) { %>
                <div class="space-y-4">
                    <% deals.forEach(deal => { %>
                        <div class="bg-white p-4 border border-slate-200 rounded-lg shadow-sm">
                            <span class="text-[10px] font-bold uppercase text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded border border-indigo-100"><%= __('From') %>: <%= deal.sender.name %></span>
                            <p class="text-xs text-slate-600 mt-2 font-medium italic">"<%= deal.message %>"</p>
                            <div class="mt-4 flex gap-2 border-t border-slate-100 pt-3">
                                <form action="/api/deals/<%= deal._id %>/status" method="POST" class="inline">
                                    <input type="hidden" name="status" value="Accepted">
                                    <button type="submit" class="bg-slate-900 text-white text-[10px] font-bold px-4 py-2 rounded cursor-pointer hover:bg-emerald-600 transition-colors"><%= __('Accept Terms') %></button>
                                </form>
                                <form action="/api/deals/<%= deal._id %>/status" method="POST" class="inline">
                                    <input type="hidden" name="status" value="Declined">
                                    <button type="submit" class="bg-slate-100 text-slate-600 text-[10px] font-bold px-4 py-2 rounded cursor-pointer border border-slate-300 hover:bg-red-50 hover:text-red-700 hover:border-red-200 transition-colors"><%= __('Decline') %></button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-sm text-slate-500 italic"><%= __('No incoming requests currently active.') %></p>
            <% } %>
        </div>
    </div>
</div>

<div class="mt-8 bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="bg-slate-900 px-6 py-4 border-b border-slate-800">
        <h2 class="text-lg font-bold text-white flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.8)]"></span>
            <%= __('Active Industrial Contracts') %>
        </h2>
    </div>
    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6 bg-slate-50">
        <% if (contracts && contracts.length > 0) { %>
            <% contracts.forEach(contract => { %>
                <% const otherParty = (contract.sender._id.toString() === user._id.toString()) ? contract.receiver : contract.sender; %>
                
                <div class="p-5 border border-emerald-200 bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-start mb-3">
                        <span class="text-[10px] font-bold text-emerald-800 uppercase tracking-wider bg-emerald-100 px-2 py-1 rounded"><%= __('Cleared for Execution') %></span>
                        <span class="text-xs text-emerald-600 font-mono"><%= new Date(contract.updatedAt).toLocaleDateString() %></span>
                    </div>
                    <h3 class="font-bold text-slate-900 text-sm mb-1"><%= __('Counterparty') %>: <%= otherParty.name %></h3>
                    <div class="flex items-center gap-2 mb-3">
                        <span class="text-xs font-semibold text-slate-500"><%= __('Secure Comm') %>:</span>
                        <a href="mailto:<%= otherParty.email %>" class="text-xs text-indigo-600 font-semibold hover:underline bg-indigo-50 px-2 py-0.5 rounded"><%= otherParty.email %></a>
                        <% if (otherParty.phone) { %>
                            <a href="tel:<%= otherParty.phone %>" class="text-xs text-emerald-600 font-semibold hover:underline bg-emerald-50 px-2 py-0.5 rounded"><%= otherParty.phone %></a>
                        <% } %>
                    </div>
                    <p class="text-xs text-slate-600 mt-3 pt-3 border-t border-slate-100">
                        <strong class="text-slate-900"><%= __('Agreed Foundation:') %></strong> "<%= contract.message %>"
                    </p>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-1 md:col-span-2 text-center py-8">
                <p class="text-sm text-slate-500 font-medium"><%= __('You currently have no active contracts.') %></p>
                <p class="text-xs text-slate-400 mt-1"><%= __('Accept a pending deal or initiate contact via the Matrix to begin execution.') %></p>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>